# Parametros de la infraestructura (sin secretos). Ajustar si hace falta.
PROJECT=exm
AWS_REGION=us-east-1
CLUSTER=exm-cluster
LOG_GROUP=/ecs/examen-devops

# Base de datos
DB_NAME=appdb
DB_MASTER_USER=admin
DB_INSTANCE_CLASS=db.t3.micro
DB_ENGINE_VERSION=8.0
DB_ALLOCATED_STORAGE=20

# Nombre base de los repos ECR (se crea uno por servicio)
ECR_NAMESPACE=examen-devops

# Tag de imagen que usan los task-defs iniciales
IMAGE_TAG=latest

# Recursos de las tasks Fargate (CPU en unidades, memoria en MiB)
BACKEND_CPU=512
BACKEND_MEM=1024
FRONTEND_CPU=256
FRONTEND_MEM=512
