# Variables para docker-compose (entorno local de desarrollo).
# Copiar a .env y ajustar los valores. NO versionar el .env real.

# MySQL local
MYSQL_ROOT_PASSWORD=cambia_este_root
DB_NAME=appdb
DB_USERNAME=appuser
DB_PASSWORD=cambia_esta_clave

# CORS: en dev se permite todo; en produccion restringir al dominio del frontend
CORS_ALLOWED_ORIGINS=*
